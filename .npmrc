# Supply-chain hardening for npm (see docs/security.md).
#
# ignore-scripts: never run dependency lifecycle scripts (pre/post-install,
#   install) during any install. This is the single largest npm supply-chain
#   attack surface (malicious postinstall hooks, e.g. the "Shai-Hulud"-style
#   worms). This project's dependencies need no install scripts, so blocking
#   them is free. The Dockerfile and CI also pass --ignore-scripts explicitly.
ignore-scripts=true

# save-exact: new dependencies are pinned to an exact version (no ^ range), so
# a fresh `npm install <pkg>` cannot silently float to a newer release.
save-exact=true

# Quality-of-life / noise reduction (no security impact).
fund=false
update-notifier=false

# NOTE: never add an `_authToken`, `//registry.../:_authToken`, or any
# credential to this committed file. Auth belongs in a machine-local, untracked
# ~/.npmrc only.
